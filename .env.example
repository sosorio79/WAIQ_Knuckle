# WAIQ Knuckle - Environment Variables (optional)
# Copy to .env and customize. NEVER commit .env to git.
# .env is in .gitignore — only this example file is committed.

# Flask port (default: 5000). Setup checks if port is free before running.
APP_PORT=5000

# Flask secret key (training default; use strong random value for any non-local use)
APP_SECRET_KEY=insecure-training-key

# SQLite database path (default: data/app.db)
# APP_DB_PATH=data/app.db

# Go SSRF proxy - only needed for SSRF module
# Local: 127.0.0.1  |  Docker: go-proxy
GO_PROXY_HOST=127.0.0.1
GO_PROXY_PORT=9000
